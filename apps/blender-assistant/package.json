{
  "name": "smolpc-blenderhelper",
  "private": true,
  "version": "7.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "tauri": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-tauri.ps1",
    "tauri:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-tauri-dev.ps1",
    "tauri:dml": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-tauri-dev.ps1 -ForceEp dml",
    "tauri:build": "npm run tauri build",
    "runtime:setup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-libs.ps1",
    "runtime:setup:sh": "bash ./scripts/setup-libs.sh",
    "bundle:stage:model": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stage-bundled-model.ps1",
    "bundle:stage:model:qwen3_5": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stage-bundled-model.ps1 -ModelId qwen3.5-2b",
    "tauri:build:self-contained": "npm run bundle:stage:model && npm run tauri build",
    "model:setup:qwen3": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-qwen3-shared-model.ps1",
    "model:setup:qwen3_5": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-qwen3.5-shared-model.ps1",
    "model:setup:qwen2_5": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-qwen2.5-shared-model.ps1",
    "model:setup:small": "npm run model:setup:qwen2_5"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^22.19.3",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "svelte": "^5.46.1",
    "svelte-check": "^4.3.5",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.3",
    "vite": "^6.4.1"
  },
  "dependencies": {
    "@tauri-apps/api": "2.10.1",
    "clsx": "^2.1.1",
    "lucide-svelte": "^0.511.0",
    "tailwind-merge": "^3.4.0"
  }
}
