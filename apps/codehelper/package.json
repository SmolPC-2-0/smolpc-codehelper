{
	"name": "@smolpc/codehelper",
	"private": true,
	"version": "2.0.0",
	"description": "SmolPC CodeHelper app (frontend + Tauri shell) that consumes the shared SmolPC engine.",
	"author": {
		"name": "Alysonhower Veras Vieira",
		"email": "contato@alysonhower.dev"
	},
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"tauri": "tauri",
		"tauri:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-tauri-dev.ps1",
		"tauri:dml": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-tauri-dml.ps1",
		"runtime:setup:openvino": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-openvino-runtime.ps1",
		"model:export:dml": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/export-dml-model.ps1",
		"model:setup:qwen3": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-qwen3-shared-model.ps1",
		"model:setup:qwen3:openvino": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/setup-openvino-qwen3-model.ps1"
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.9",
		"@lucide/svelte": "^0.511.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@tauri-apps/cli": "^2.5.0",
		"@tsconfig/svelte": "^5.0.4",
		"eslint": "^9.27.0",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-svelte": "^3.8.1",
		"prettier": "^3.5.3",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"svelte": "^5.28.1",
		"svelte-check": "^4.1.6",
		"tailwind-variants": "^0.2.1",
		"tw-animate-css": "^1.3.0",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.32.1",
		"vite": "^6.3.5"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.1.7",
		"@tauri-apps/api": "^2.5.0",
		"@types/dompurify": "^3.0.5",
		"@types/node": "^22.15.19",
		"clsx": "^2.1.1",
		"dompurify": "^3.3.0",
		"isomorphic-dompurify": "^2.33.0",
		"tailwind-merge": "^3.3.0",
		"tailwindcss": "^4.1.7"
	}
}
