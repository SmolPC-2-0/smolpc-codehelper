{
	"$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "SmolPC Launcher",
	"version": "1.0.0",
	"identifier": "com.smolpc.launcher",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:1421",
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build"
	},
	"app": {
		"windows": [
			{
				"title": "SmolPC Launcher",
				"width": 500,
				"height": 400,
				"resizable": true,
				"fullscreen": false,
				"devtools": false
			}
		],
		"security": {
			"csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data:; object-src 'none'; base-uri 'self'; form-action 'self'"
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": [
			"resources/launcher/*",
			"libs/*"
		]
	}
}
