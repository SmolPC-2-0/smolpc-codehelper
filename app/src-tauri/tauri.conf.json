{
	"$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "SmolPC Code Helper",
	"version": "2.2.0",
	"identifier": "com.smolpc.codehelper",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build"
	},
	"app": {
		"windows": [
			{
				"title": "SmolPC Code Helper",
				"width": 1000,
				"height": 800,
				"resizable": true,
				"fullscreen": false,
				"devtools": true
			}
		],
		"security": {
			"csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' http://localhost:11434 http://127.0.0.1:11434; object-src 'none'; base-uri 'self'; form-action 'self'"
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"resources": {
			"libs/": "libs/",
			"binaries/": "binaries/",
			"resources/launcher/": "launcher/",
			"resources/model-installer/": "model-installer/",
			"resources/gimp/": "gimp/",
			"../../connectors/blender/resources/": "blender/",
			"resources/libreoffice/": "libreoffice/",
			"resources/python/": "python/",
			"resources/models/": "models/"
		},
		"windows": {
			"webviewInstallMode": {
				"type": "offlineInstaller",
				"silent": true
			},
			"nsis": {
				"installMode": "currentUser"
			}
		}
	}
}
